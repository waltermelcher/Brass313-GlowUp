---
import { NAV, SITE, url, asset } from '../consts';
const year = 2026;
---

<footer class="footer">
  <div class="divider"></div>
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href={url('')} class="footer__logo">
        <img src={asset('images/logo.png')} alt="" width="48" height="50" />
        <span class="footer__word">Brass<span class="brand__dot">.</span>313</span>
      </a>
      <p class="footer__claim">{SITE.claim}</p>
      <p class="footer__desc muted">{SITE.description}</p>
    </div>

    <div class="footer__col">
      <h4 class="footer__head">Die Strecke</h4>
      <ul>
        {NAV.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </div>

    <div class="footer__col">
      <h4 class="footer__head">Kontakt</h4>
      <ul>
        <li><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
        <li><a href={SITE.instagram} target="_blank" rel="noopener">Instagram · @brass.313</a></li>
        <li><a href={url('impressum-datenschutz')}>Impressum &amp; Datenschutz</a></li>
      </ul>
    </div>
  </div>

  <div class="container footer__bottom">
    <span>© {year} {SITE.name} — Blasmusik aus'm Ländle</span>
    <span class="footer__legal">
      <a href={url('impressum-datenschutz')}>Impressum</a>
      <a href={url('impressum-datenschutz')}>Datenschutz</a>
    </span>
  </div>
</footer>

<style>
  .footer { padding-top: 3rem; }
  .footer__inner {
    display: grid;
    grid-template-columns: 1.7fr 1fr 1fr;
    gap: 3rem;
    padding-block: 3.5rem;
    padding-left: clamp(2.4rem, 6vw, 4.5rem);
  }
  .footer__logo { display: inline-flex; align-items: center; gap: 0.6rem; }
  .footer__logo img { height: 46px; width: auto; }
  .footer__word {
    font-family: var(--font-sign);
    font-weight: 700;
    font-size: 1.5rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .brand__dot { color: var(--signal); }
  .footer__claim {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.4rem;
    color: var(--messing-hell);
    margin: 1.1rem 0 0.7rem;
  }
  .footer__desc { max-width: 42ch; font-size: 0.98rem; }

  .footer__head {
    font-family: var(--font-sign);
    font-weight: 600;
    font-size: 0.74rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: 1.2rem;
  }
  .footer__col ul { list-style: none; display: flex; flex-direction: column; gap: 0.7rem; }
  .footer__col a { color: var(--muted); transition: color 0.3s var(--ease); font-size: 1rem; }
  .footer__col a:hover { color: var(--messing-hell); }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    padding-block: 1.6rem 2.4rem;
    padding-left: clamp(2.4rem, 6vw, 4.5rem);
    border-top: 1px solid var(--line);
    color: var(--dim);
    font-size: 0.86rem;
    font-family: var(--font-sign);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .footer__legal { display: flex; gap: 1.4rem; }
  .footer__legal a:hover { color: var(--messing-hell); }

  @media (max-width: 760px) { .footer__inner { grid-template-columns: 1fr; gap: 2.4rem; } }
</style>
