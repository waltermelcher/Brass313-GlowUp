---
import { NAV, SITE, url, asset } from '../consts';
const year = 2026;
---

<footer class="footer">
  <div class="divider"></div>
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href={url('')} class="footer__logo">
        <img src={asset('images/logo.png')} alt="Brass.313 Logo" width="56" height="58" />
      </a>
      <p class="footer__claim">{SITE.claim}</p>
      <p class="footer__desc">{SITE.description}</p>
    </div>

    <div class="footer__col">
      <h4 class="footer__head">Navigation</h4>
      <ul>
        {NAV.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer__col">
      <h4 class="footer__head">Kontakt</h4>
      <ul>
        <li><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
        <li><a href={SITE.instagram} target="_blank" rel="noopener">Folge uns auf Instagram</a></li>
        <li><a href={url('impressum-datenschutz')}>Impressum &amp; Datenschutz</a></li>
      </ul>
    </div>
  </div>

  <div class="container footer__bottom">
    <span>© {year} {SITE.name} — Blasmusik aus'm Ländle</span>
    <span class="footer__legal">
      <a href={url('impressum-datenschutz')}>Impressum</a>
      <a href={url('impressum-datenschutz')}>Datenschutz</a>
    </span>
  </div>
</footer>

<style>
  .footer { padding-top: 3.5rem; }
  .footer__inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 3rem;
    padding-block: 3.5rem;
  }
  .footer__logo img { height: 54px; width: auto; margin-bottom: 1.2rem; }
  .footer__claim {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--gold);
    margin-bottom: 0.8rem;
  }
  .footer__desc { color: var(--text-muted); max-width: 42ch; font-size: 0.96rem; }

  .footer__head {
    font-family: var(--font-body);
    font-size: 0.78rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 1.2rem;
  }
  .footer__col ul { list-style: none; display: flex; flex-direction: column; gap: 0.7rem; }
  .footer__col a {
    color: var(--text-muted);
    transition: color 0.3s var(--ease);
    font-size: 0.96rem;
  }
  .footer__col a:hover { color: var(--gold); }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    padding-block: 1.8rem 2.5rem;
    border-top: 1px solid var(--line);
    color: var(--text-dim);
    font-size: 0.85rem;
  }
  .footer__legal { display: flex; gap: 1.5rem; }
  .footer__legal a:hover { color: var(--gold); }

  @media (max-width: 760px) {
    .footer__inner { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>
