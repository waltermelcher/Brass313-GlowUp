---
import { asset } from '../consts';
interface Props {
  km: string;
  label: string;
  title: string;
  text?: string;
  image: string;
}
const { km, label, title, text, image } = Astro.props;
---

<section class="page-hero" data-km={km} data-label={label}>
  <div class="page-hero__media">
    <img src={asset(image)} alt="" fetchpriority="high" />
    <div class="page-hero__overlay"></div>
  </div>
  <div class="container page-hero__content">
    <span class="km" data-reveal><span class="km__dot"></span>KM {km} · {label}</span>
    <h1 class="page-hero__title" data-reveal style="--reveal-delay:.08s">{title}</h1>
    {text && <p class="lead page-hero__text" data-reveal style="--reveal-delay:.16s">{text}</p>}
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    min-height: 58vh;
    display: flex;
    align-items: flex-end;
    padding-block: calc(var(--header-h) + 2.5rem) clamp(2.5rem, 6vw, 4.5rem);
    overflow: hidden;
  }
  .page-hero__media { position: absolute; inset: 0; z-index: -1; }
  .page-hero__media img { width: 100%; height: 100%; object-fit: cover; object-position: center 28%; }
  .page-hero__overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(22,19,15,0.72) 0%, rgba(22,19,15,0.32) 38%, rgba(22,19,15,0.92) 92%, var(--nacht) 100%),
      radial-gradient(120% 90% at 12% 96%, rgba(182,130,46,0.18), transparent 60%);
  }
  .page-hero__content { padding-left: clamp(2.4rem, 6vw, 4.5rem); }
  .page-hero__title { font-size: clamp(2.6rem, 9vw, 6rem); margin: 0.7rem 0 1rem; }
  .page-hero__text { max-width: 56ch; }
</style>
