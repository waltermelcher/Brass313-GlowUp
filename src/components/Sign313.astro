---
// German Bundesstraße marker — the band's namesake, rendered as the real road sign.
interface Props {
  size?: 'sm' | 'md' | 'lg';
}
const { size = 'md' } = Astro.props;
---

<span class:list={['sign313', `sign313--${size}`]} role="img" aria-label="Bundesstraße B 313">
  <span class="sign313__b">B</span>
  <span class="sign313__n">313</span>
</span>

<style>
  .sign313 {
    display: inline-flex;
    align-items: baseline;
    gap: 0.18em;
    background: var(--signal);
    color: var(--nacht);
    font-family: var(--font-sign);
    font-weight: 700;
    line-height: 1;
    padding: 0.34em 0.5em 0.3em;
    border-radius: 0.28em;
    box-shadow:
      inset 0 0 0 0.13em var(--nacht),
      0 8px 26px -10px rgba(255, 210, 30, 0.5);
    letter-spacing: 0.01em;
  }
  .sign313__b { font-size: 0.52em; align-self: flex-start; margin-top: 0.18em; font-weight: 600; }
  .sign313__n { font-size: 1em; }

  .sign313--sm { font-size: 1.1rem; padding: 0.3em 0.42em; }
  .sign313--md { font-size: 2rem; }
  .sign313--lg { font-size: clamp(2.6rem, 7vw, 4.6rem); }
</style>
