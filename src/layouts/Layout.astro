---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE, asset } from '../consts';

interface Props {
  title?: string;
  description?: string;
}
const { title, description = SITE.description } = Astro.props;
const fullTitle = title ? `${title} · ${SITE.name}` : `${SITE.name} — ${SITE.claim}`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={asset('images/logo.png')} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={asset('images/band-01.jpg')} />
    <meta name="theme-color" content="#16130f" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Spectral:ital,wght@0,400;0,500;1,400;1,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- ===== Signature: die B313-Route (Straße + Notenlinie) ===== -->
    <aside class="route" aria-hidden="true">
      <span class="route__line"></span>
      <span class="route__fill" id="route-fill"></span>
      <span class="route__marker" id="route-marker"></span>
      <span class="route__km" id="route-km"></span>
    </aside>

    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <style>
      .route {
        position: fixed;
        top: 0;
        bottom: 0;
        left: clamp(0.85rem, 2.4vw, 1.9rem);
        width: 2px;
        z-index: 40;
        pointer-events: none;
      }
      .route__line {
        position: absolute;
        inset: 0;
        background:
          repeating-linear-gradient(
            to bottom,
            var(--line-strong) 0 10px,
            transparent 10px 22px
          );
        opacity: 0.7;
      }
      .route__fill {
        position: absolute;
        top: 0;
        left: 0;
        width: 2px;
        height: 0;
        background: linear-gradient(var(--messing-hell), var(--messing));
        box-shadow: 0 0 12px -2px var(--messing-glow);
      }
      /* the travelling marker = the car on the B313 (signal yellow, reserved) */
      .route__marker {
        position: absolute;
        top: 0;
        left: 50%;
        width: 13px;
        height: 13px;
        transform: translate(-50%, -50%);
        border-radius: 50%;
        background: var(--signal);
        box-shadow: 0 0 0 4px rgba(255, 210, 30, 0.18), 0 0 16px 0 rgba(255, 210, 30, 0.5);
      }
      .route__km {
        position: absolute;
        left: 16px;
        top: 0;
        transform: translateY(-50%);
        font-family: var(--font-sign);
        font-weight: 600;
        font-size: 0.62rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--messing-hell);
        white-space: nowrap;
        opacity: 0;
        transition: opacity 0.4s var(--ease);
      }
      .route.active .route__km { opacity: 0.9; }

      @media (max-width: 720px) {
        .route { left: 0.5rem; }
        .route__km { display: none; }
      }
    </style>

    <script>
      // Route-Fortschritt: der Marker fährt die B313 entlang (Scroll-Progress).
      const fill = document.getElementById('route-fill');
      const marker = document.getElementById('route-marker');
      const kmLabel = document.getElementById('route-km');
      const routeEl = document.querySelector('.route');
      let ticking = false;

      const update = () => {
        const max = document.documentElement.scrollHeight - window.innerHeight;
        const p = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
        const vh = window.innerHeight;
        if (fill) fill.style.height = `${p * vh}px`;
        if (marker) marker.style.top = `${p * vh}px`;
        ticking = false;
      };
      const onScroll = () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', update);
      update();

      // aktuelle "Station" (km-Label) je nach sichtbarem Abschnitt
      const stops = document.querySelectorAll('[data-km]');
      if (stops.length && kmLabel) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                const el = e.target as HTMLElement;
                kmLabel.textContent = `KM ${el.dataset.km} · ${el.dataset.label ?? ''}`;
                routeEl?.classList.add('active');
              }
            });
          },
          { rootMargin: '-45% 0px -45% 0px' }
        );
        stops.forEach((s) => io.observe(s));
      }

      // dezente Scroll-Reveals
      const els = document.querySelectorAll('[data-reveal]');
      if (els.length) {
        const io2 = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('in-view');
                io2.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        els.forEach((el) => io2.observe(el));
      }
    </script>
  </body>
</html>
