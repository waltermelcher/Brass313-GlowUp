---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { OFFERS, SITE, url, asset } from '../consts';

const imgs = ['images/gig-01.jpg', 'images/band-03.jpg', 'images/gig-05.jpg', 'images/band-06.jpg'];
---

<Layout title="Auftritte" description="Konzertreihen, Festzeltauftritte, Event-Umrahmungen und Firmenfeiern mit Brass.313.">
  <PageHero
    km="A"
    label="Die Strecke"
    title="Live & handgemacht"
    text="Ob bestuhltes Konzert, tobendes Festzelt oder stilvolle Firmenfeier — Brass.313 bringt für jeden Abschnitt den passenden Sound mit."
    image="images/band-05.jpg"
  />

  <section class="section-pad" data-km="A1" data-label="Abschnitte">
    <div class="container lane">
      <div class="segments">
        {OFFERS.map((o, i) => (
          <article class="segment" data-reveal style={`--reveal-delay:${i * 0.05}s`}>
            <div class="segment__head">
              <span class="segment__tag">Abschnitt {String(i + 1).padStart(2, '0')}</span>
              <h2 class="segment__title">{o.title}</h2>
              <p class="segment__text muted">{o.text}</p>
            </div>
            <img class="segment__img" src={asset(imgs[i])} alt={o.title} loading="lazy" />
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad" style="padding-top:0" data-km="A2" data-label="Impressionen">
    <div class="container lane">
      <div class="sec-head" data-reveal>
        <span class="km"><span class="km__dot"></span>Impressionen</span>
        <h2 class="section-title">Brass.313 in Aktion</h2>
      </div>
      <div class="gallery">
        <img src={asset('images/band-01.jpg')} alt="Brass.313 live" loading="lazy" data-reveal />
        <img src={asset('images/gig-02.jpg')} alt="Brass.313 Auftritt" loading="lazy" data-reveal style="--reveal-delay:.06s" />
        <img src={asset('images/band-08.jpg')} alt="Brass.313 Ensemble" loading="lazy" data-reveal style="--reveal-delay:.12s" />
        <img src={asset('images/gig-05.jpg')} alt="Brass.313 Bühne" loading="lazy" data-reveal />
        <img src={asset('images/band-06.jpg')} alt="Brass.313 Porträt" loading="lazy" data-reveal style="--reveal-delay:.06s" />
        <img src={asset('images/gig-01.jpg')} alt="Brass.313 Konzert" loading="lazy" data-reveal style="--reveal-delay:.12s" />
      </div>
    </div>
  </section>

  <section class="section-pad" style="padding-top:0" data-km="A3" data-label="Anfrage">
    <div class="container lane cta center" data-reveal>
      <h2 class="cta__title">Klingt nach eurem Event?</h2>
      <p class="lead mx-auto">Erzählt uns von eurem Anlass — wir melden uns mit einem passenden Vorschlag.</p>
      <div class="actions" style="margin-top:2rem">
        <a class="btn btn-primary" href={url('kontakt')}>Jetzt anfragen <span class="arr">→</span></a>
        <a class="btn btn-ghost" href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .segments { display: flex; flex-direction: column; gap: 1rem; }
  .segment {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 2.5rem;
    align-items: center;
    padding: 1.8rem 0;
    border-bottom: 1px solid var(--line);
  }
  .segment:first-child { border-top: 1px solid var(--line); }
  .segment__tag { font-family: var(--font-sign); font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--messing-tief); }
  .segment__title { font-size: clamp(1.7rem, 3.4vw, 2.5rem); margin: 0.5rem 0 0.7rem; color: var(--messing-hell); }
  .segment__text { max-width: 54ch; }
  .segment__img {
    width: 340px;
    height: 215px;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid var(--line);
    transition: transform 0.5s var(--ease);
  }
  .segment:hover .segment__img { transform: scale(1.03); }
  @media (max-width: 880px) {
    .segment { grid-template-columns: 1fr; gap: 1.2rem; }
    .segment__img { width: 100%; height: 200px; order: -1; }
  }

  .gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.8rem; }
  .gallery img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid var(--line);
    filter: grayscale(0.2) brightness(0.95);
    transition: transform 0.5s var(--ease), filter 0.5s var(--ease);
  }
  .gallery img:hover { transform: scale(1.02); filter: none; }
  @media (max-width: 760px) { .gallery { grid-template-columns: repeat(2, 1fr); } }

  .cta { max-width: 720px; }
  .cta__title { font-size: clamp(2.2rem, 5vw, 3.6rem); margin-bottom: 1.2rem; }
  .actions { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }
</style>
