</Layout>

<style>
  .legal { padding-block: calc(var(--header-h) + 3.5rem) clamp(4rem, 9vw, 7rem); }
  .legal__inner { max-width: 820px; }
  .legal__top { margin-bottom: 3rem; }
  .legal__title { font-size: clamp(2.4rem, 6vw, 4rem); margin: 0.5rem 0 1.5rem; }
  .legal__placeholder-note {
    background: rgba(201,162,75,0.08);
    border: 1px solid var(--gold-deep);
    border-radius: 10px;
    padding: 1rem 1.2rem;
    color: var(--gold-bright);
    font-size: 0.92rem;
  }
  .legal__block h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin-bottom: 1.5rem;
    color: var(--gold);
  }
  .legal__block h3 {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: 0.01em;
    margin: 2rem 0 0.6rem;
    color: var(--text);
  }
  .legal__block p { color: var(--text-muted); margin-bottom: 0.8rem; }
  .legal__updated { font-size: 0.85rem; color: var(--text-dim); margin-top: 2rem; }
</style>
