---
import Layout from '../layouts/Layout.astro';
import { SITE, OFFERS, GIGS, MUSICIANS, url, asset } from '../consts';
---

<Layout>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="hero__media">
      <img src={asset('images/band-04.jpg')} alt="Brass.313 live auf der Bühne" fetchpriority="high" />
      <div class="hero__overlay"></div>
    </div>
    <div class="container hero__content">
      <span class="eyebrow" data-reveal>Blasmusik · Württemberg · B313</span>
      <h1 class="display hero__title" data-reveal style="--reveal-delay:.08s">Brass<span class="dot">.</span>313</h1>
      <p class="hero__claim" data-reveal style="--reveal-delay:.16s">{SITE.claim}</p>
      <p class="lead hero__lead" data-reveal style="--reveal-delay:.24s">{SITE.description}</p>
      <div class="hero__actions" data-reveal style="--reveal-delay:.32s">
        <a class="btn btn-primary" href={url('termine')}>Nächste Auftritte</a>
        <a class="btn btn-ghost" href={url('kontakt')}>Buchungsanfrage</a>
      </div>
    </div>
    <a href="#intro" class="hero__scroll" aria-label="Weiter scrollen">
      <span>Scroll</span>
      <span class="hero__scroll-line"></span>
    </a>
  </section>

  <!-- ============ INTRO / NAME ============ -->
  <section id="intro" class="section-pad">
    <div class="container intro">
      <div class="intro__text">
        <span class="eyebrow" data-reveal>Wer wir sind</span>
        <h2 class="section-title" data-reveal>Sieben Musiker, eine Leidenschaft.</h2>
        <div class="stack" data-reveal style="--reveal-delay:.1s">
          <p class="lead">
            Brass.313 verbindet traditionelle Blasmusik mit modernen Pop-Arrangements zu einem
            einzigartigen Klangerlebnis — handgemacht, druckvoll und mit Herz.
          </p>
          <p class="intro__meta">
            Der Name ist Programm: <span class="gold-text">3 hohe Bläser</span>,
            <span class="gold-text">1 Schlagzeuger</span> und
            <span class="gold-text">3 tiefe Bläser</span> — und die
            <span class="gold-text">313</span> für die Bundesstraße B313, die sich durch
            unsere Heimat im Ländle zieht.
          </p>
        </div>
        <a class="btn btn-ghost" href={url('musiker')} data-reveal style="--reveal-delay:.18s">
          Die Musiker kennenlernen →
        </a>
      </div>
      <div class="intro__images" data-reveal style="--reveal-delay:.12s">
        <img class="intro__img intro__img--a" src={asset('images/band-01.jpg')} alt="Brass.313 Porträt" loading="lazy" />
        <img class="intro__img intro__img--b" src={asset('images/gig-02.jpg')} alt="Brass.313 beim Auftritt" loading="lazy" />
        <div class="intro__badge">313</div>
      </div>
    </div>
  </section>

  <!-- ============ OFFERS ============ -->
  <section class="section-pad offers-sec">
    <div class="container">
      <div class="sec-head" data-reveal>
        <span class="eyebrow">Auftritte</span>
        <h2 class="section-title">Für jeden Anlass der richtige Sound</h2>
      </div>
      <div class="offers">
        {OFFERS.map((o, i) => (
          <article class="offer-card" data-reveal style={`--reveal-delay:${i * 0.07}s`}>
            <span class="offer-card__num">0{i + 1}</span>
            <h3 class="offer-card__title">{o.title}</h3>
            <p class="offer-card__text">{o.text}</p>
          </article>
        ))}
      </div>
      <div class="center" style="margin-top:2.5rem" data-reveal>
        <a class="btn btn-primary" href={url('auftritte')}>Alle Auftrittsformen</a>
      </div>
    </div>
  </section>

  <!-- ============ NEXT GIGS ============ -->
  <section class="section-pad gigs-sec">
    <div class="container">
      <div class="sec-head sec-head--row" data-reveal>
        <div>
          <span class="eyebrow">Termine 2026</span>
          <h2 class="section-title">Wo ihr uns hört</h2>
        </div>
        <a class="btn btn-ghost gigs-sec__cta" href={url('termine')}>Alle Termine</a>
      </div>
      <ul class="gig-list">
        {GIGS.map((g, i) => (
          <li class="gig" data-reveal style={`--reveal-delay:${i * 0.06}s`}>
            <div class="gig__date">
              <span class="gig__day">{g.day}</span>
              <span class="gig__month">{g.month}</span>
            </div>
            <div class="gig__main">
              <h3 class="gig__title">{g.title}</h3>
              <p class="gig__loc">{g.location}</p>
            </div>
            <div class="gig__meta">
              <span class="gig__time">{g.time}</span>
              <span class="gig__note">{g.note}</span>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============ MUSICIANS BAND ============ -->
  <section class="band-strip">
    <div class="band-strip__media">
      <img src={asset('images/band-08.jpg')} alt="Brass.313 Ensemble" loading="lazy" />
      <div class="band-strip__overlay"></div>
    </div>
    <div class="container band-strip__content">
      <span class="eyebrow" data-reveal>Das Ensemble</span>
      <h2 class="section-title" data-reveal>Die Köpfe hinter Brass.313</h2>
      <ul class="band-names" data-reveal style="--reveal-delay:.1s">
        {MUSICIANS.map((m) => <li>{m.name}</li>)}
      </ul>
      <a class="btn btn-ghost" href={url('musiker')} data-reveal style="--reveal-delay:.18s">Mehr über die Band</a>
    </div>
  </section>

  <!-- ============ CONTACT CTA ============ -->
  <section class="section-pad">
    <div class="container cta">
      <div data-reveal>
        <span class="eyebrow">Buchung &amp; Kontakt</span>
        <h2 class="cta__title">Holt euch Brass.313<br />auf eure Bühne.</h2>
        <p class="lead mx-auto">
          Konzert, Festzelt, Firmenfeier oder Event-Umrahmung — schreibt uns, und wir stimmen
          alles individuell auf euren Anlass ab.
        </p>
        <div class="hero__actions" style="justify-content:center;margin-top:2rem">
          <a class="btn btn-primary" href={`mailto:${SITE.email}`}>{SITE.email}</a>
          <a class="btn btn-ghost" href={url('kontakt')}>Zum Kontaktformular</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* HERO */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    padding-bottom: clamp(3rem, 8vh, 6rem);
    overflow: hidden;
  }
  .hero__media { position: absolute; inset: 0; z-index: -1; }
  .hero__media img { width: 100%; height: 100%; object-fit: cover; object-position: center 30%; }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(10,10,12,0.55) 0%, rgba(10,10,12,0.2) 35%, rgba(10,10,12,0.85) 88%, var(--bg) 100%),
      radial-gradient(120% 80% at 20% 90%, rgba(201,162,75,0.18), transparent 60%);
  }
  .hero__content { position: relative; }
  .hero__title { margin: 0.5rem 0 0.2rem; }
  .hero__title .dot { color: var(--gold); }
  .hero__claim {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 4vw, 2.4rem);
    color: var(--gold-bright);
    font-style: italic;
    margin-bottom: 1.3rem;
  }
  .hero__lead { margin-bottom: 2rem; }
  .hero__actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  .hero__scroll {
    position: absolute;
    right: var(--gutter);
    bottom: clamp(3rem, 8vh, 6rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.7rem;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text-muted);
    writing-mode: vertical-rl;
  }
  .hero__scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(var(--gold), transparent);
    animation: scrollpulse 2.2s var(--ease) infinite;
  }
  @keyframes scrollpulse {
    0%, 100% { transform: scaleY(0.4); transform-origin: top; opacity: 0.5; }
    50% { transform: scaleY(1); opacity: 1; }
  }
  @media (max-width: 700px) { .hero__scroll { display: none; } }

  /* INTRO */
  .intro {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }
  .intro__meta { color: var(--text-muted); font-size: 1.05rem; }
  .intro .btn { margin-top: 1.8rem; }
  .intro__images { position: relative; aspect-ratio: 4/5; }
  .intro__img {
    position: absolute;
    border-radius: var(--radius);
    object-fit: cover;
    box-shadow: 0 30px 60px -25px rgba(0,0,0,0.8);
    border: 1px solid var(--line);
  }
  .intro__img--a { width: 72%; height: 82%; top: 0; left: 0; z-index: 2; }
  .intro__img--b { width: 52%; height: 56%; bottom: 0; right: 0; z-index: 3; }
  .intro__badge {
    position: absolute;
    top: 8%;
    right: 4%;
    z-index: 4;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2rem, 5vw, 3.2rem);
    color: var(--gold);
    background: rgba(10,10,12,0.7);
    backdrop-filter: blur(6px);
    border: 1px solid var(--gold-deep);
    border-radius: 50%;
    width: clamp(72px, 11vw, 108px);
    height: clamp(72px, 11vw, 108px);
    display: grid;
    place-items: center;
    box-shadow: 0 0 40px -8px var(--gold-glow);
  }
  @media (max-width: 820px) {
    .intro { grid-template-columns: 1fr; }
    .intro__images { max-width: 460px; }
  }

  /* SECTION HEAD */
  .sec-head { margin-bottom: 3rem; max-width: 60ch; }
  .sec-head--row { display: flex; align-items: flex-end; justify-content: space-between; gap: 2rem; max-width: none; }

  /* OFFERS */
  .offers-sec { background: linear-gradient(180deg, transparent, rgba(255,255,255,0.015)); }
  .offers { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.2rem; }
  .offer-card {
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 2rem 1.6rem;
    transition: transform 0.4s var(--ease), border-color 0.4s var(--ease), background 0.4s var(--ease);
  }
  .offer-card:hover {
    transform: translateY(-6px);
    border-color: var(--gold-deep);
    background: var(--bg-elev-2);
  }
  .offer-card__num {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--gold);
    letter-spacing: 0.05em;
  }
  .offer-card__title { font-size: 1.35rem; margin: 0.8rem 0 0.7rem; }
  .offer-card__text { color: var(--text-muted); font-size: 0.96rem; }
  @media (max-width: 920px) { .offers { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .offers { grid-template-columns: 1fr; } }

  /* GIGS */
  .gig-list { list-style: none; }
  .gig {
    display: grid;
    grid-template-columns: 90px 1fr auto;
    gap: 1.8rem;
    align-items: center;
    padding: 1.5rem 0;
    border-top: 1px solid var(--line);
    transition: padding-left 0.35s var(--ease);
  }
  .gig:last-child { border-bottom: 1px solid var(--line); }
  .gig:hover { padding-left: 0.8rem; }
  .gig__date {
    display: flex;
    flex-direction: column;
    align-items: center;
    border-right: 1px solid var(--line);
    padding-right: 1.2rem;
  }
  .gig__day { font-family: var(--font-display); font-size: 2.2rem; line-height: 1; color: var(--gold); }
  .gig__month { font-size: 0.78rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-dim); }
  .gig__title { font-size: 1.4rem; }
  .gig__loc { color: var(--text-muted); font-size: 0.95rem; }
  .gig__meta { text-align: right; }
  .gig__time { display: block; font-weight: 600; color: var(--text); }
  .gig__note { font-size: 0.85rem; color: var(--text-dim); }
  @media (max-width: 640px) {
    .gig { grid-template-columns: 70px 1fr; gap: 1.2rem; }
    .gig__meta { grid-column: 2; text-align: left; }
  }

  /* BAND STRIP */
  .band-strip { position: relative; padding-block: clamp(6rem, 14vw, 11rem); overflow: hidden; }
  .band-strip__media { position: absolute; inset: 0; z-index: -1; }
  .band-strip__media img { width: 100%; height: 100%; object-fit: cover; object-position: center 25%; }
  .band-strip__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(90deg, rgba(10,10,12,0.95) 0%, rgba(10,10,12,0.75) 45%, rgba(10,10,12,0.45) 100%);
  }
  .band-strip__content { max-width: 640px; }
  .band-names {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.4rem;
    margin: 1.6rem 0 2rem;
  }
  .band-names li {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2.4vw, 1.6rem);
    color: var(--text);
    position: relative;
    padding-right: 1.4rem;
  }
  .band-names li:not(:last-child)::after {
    content: '·';
    position: absolute;
    right: 0;
    color: var(--gold);
  }

  /* CTA */
  .cta { text-align: center; max-width: 760px; }
  .cta__title {
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    margin: 0.6rem 0 1.4rem;
  }
</style>
