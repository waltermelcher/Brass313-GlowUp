---
import Layout from '../layouts/Layout.astro';
import Sign313 from '../components/Sign313.astro';
import { SITE, OFFERS, GIGS, MUSICIANS, url, asset } from '../consts';
---

<Layout>
  <!-- ============ HERO · KM 00 ============ -->
  <section class="hero" data-km="00" data-label="Start">
    <div class="hero__media">
      <img src={asset('images/band-04.jpg')} alt="Brass.313 live" fetchpriority="high" />
      <div class="hero__overlay"></div>
    </div>
    <div class="container hero__content lane">
      <div class="hero__sign" data-reveal><Sign313 size="lg" /><span class="hero__sign-cap">Württemberg · die Strecke der Band</span></div>
      <h1 class="display hero__title" data-reveal style="--reveal-delay:.08s">Brass<span class="dot">.</span>313</h1>
      <p class="hero__claim" data-reveal style="--reveal-delay:.16s">{SITE.claim}</p>
      <p class="lead hero__lead" data-reveal style="--reveal-delay:.24s">{SITE.description}</p>
      <div class="hero__actions" data-reveal style="--reveal-delay:.32s">
        <a class="btn btn-primary" href={url('termine')}>Nächster Halt <span class="arr">→</span></a>
        <a class="btn btn-ghost" href={url('kontakt')}>Buchungsanfrage</a>
      </div>
    </div>
  </section>

  <!-- ============ KM 01 · Wer wir sind ============ -->
  <section class="section-pad" data-km="01" data-label="Wer wir sind">
    <div class="container lane intro">
      <div class="intro__text">
        <span class="km" data-reveal><span class="km__dot"></span>KM 01 · Wer wir sind</span>
        <h2 class="section-title" data-reveal>Sieben Musiker,<br />eine Leidenschaft</h2>
        <div class="stack" data-reveal style="--reveal-delay:.1s">
          <p class="lead">
            Brass.313 verbindet traditionelle Blasmusik mit modernen Pop-Arrangements zu einem
            einzigartigen Klangerlebnis — handgemacht, druckvoll und mit Herz.
          </p>
          <p class="muted">
            Der Name ist die Landkarte der Band: <span class="brass-text">3 hohe Bläser</span>,
            <span class="brass-text">1 Schlagzeuger</span> und
            <span class="brass-text">3 tiefe Bläser</span> — die <span class="brass-text">313</span>
            für die Bundesstraße B313, die sich durch unsere Heimat im Ländle zieht.
          </p>
        </div>
        <a class="btn btn-ghost" href={url('musiker')} data-reveal style="--reveal-delay:.18s">Die Besetzung <span class="arr">→</span></a>
      </div>
      <div class="intro__images" data-reveal style="--reveal-delay:.12s">
        <img class="intro__img intro__img--a" src={asset('images/band-01.jpg')} alt="Brass.313 Porträt" loading="lazy" />
        <img class="intro__img intro__img--b" src={asset('images/gig-02.jpg')} alt="Brass.313 beim Auftritt" loading="lazy" />
        <span class="intro__formation" aria-label="Formation 3-1-3">3·1·3</span>
      </div>
    </div>
  </section>

  <!-- ============ KM 02 · Die Strecke (Auftritte) ============ -->
  <section class="section-pad segments-sec" data-km="02" data-label="Die Strecke">
    <div class="container lane">
      <div class="sec-head" data-reveal>
        <span class="km"><span class="km__dot"></span>KM 02 · Die Strecke</span>
        <h2 class="section-title">Für jeden Anlass<br />der richtige Sound</h2>
      </div>
      <div class="segments">
        {OFFERS.map((o, i) => (
          <article class="segment" data-reveal style={`--reveal-delay:${i * 0.07}s`}>
            <span class="segment__tag">Abschnitt {String(i + 1).padStart(2, '0')}</span>
            <h3 class="segment__title">{o.title}</h3>
            <p class="segment__text muted">{o.text}</p>
          </article>
        ))}
      </div>
      <div class="center" style="margin-top:2.5rem" data-reveal>
        <a class="btn btn-primary" href={url('auftritte')}>Alle Auftrittsformen <span class="arr">→</span></a>
      </div>
    </div>
  </section>

  <!-- ============ KM 03 · Nächster Halt (Termine) ============ -->
  <section class="section-pad" data-km="03" data-label="Nächster Halt">
    <div class="container lane">
      <div class="sec-head sec-head--row" data-reveal>
        <div>
          <span class="km"><span class="km__dot"></span>KM 03 · Nächster Halt</span>
          <h2 class="section-title">Wo ihr uns hört</h2>
        </div>
        <a class="btn btn-ghost gigs__cta" href={url('termine')}>Alle Termine 2026</a>
      </div>
      <ul class="stops">
        {GIGS.map((g, i) => (
          <li class="stop" data-reveal style={`--reveal-delay:${i * 0.06}s`}>
            <span class="stop__node"></span>
            <div class="stop__date">
              <span class="stop__day">{g.day}</span>
              <span class="stop__month">{g.month}</span>
            </div>
            <div class="stop__main">
              <h3 class="stop__title">{g.title}</h3>
              <p class="stop__loc muted">{g.location}</p>
            </div>
            <div class="stop__meta">
              <span class="stop__time">{g.time}</span>
              <span class="stop__note muted">{g.note}</span>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============ KM 04 · Die Besetzung (Musiker) ============ -->
  <section class="band-strip" data-km="04" data-label="Die Besetzung">
    <div class="band-strip__media">
      <img src={asset('images/band-08.jpg')} alt="Brass.313 Ensemble" loading="lazy" />
      <div class="band-strip__overlay"></div>
    </div>
    <div class="container lane band-strip__content">
      <span class="km" data-reveal><span class="km__dot"></span>KM 04 · Die Besetzung</span>
      <h2 class="section-title" data-reveal>Die Köpfe<br />hinter Brass.313</h2>
      <ul class="band-names" data-reveal style="--reveal-delay:.1s">
        {MUSICIANS.map((m) => <li>{m.name}</li>)}
      </ul>
      <a class="btn btn-ghost" href={url('musiker')} data-reveal style="--reveal-delay:.18s">Mehr über die Band <span class="arr">→</span></a>
    </div>
  </section>

  <!-- ============ KM 05 · Buchung ============ -->
  <section class="section-pad" data-km="05" data-label="Buchung">
    <div class="container lane cta" data-reveal>
      <span class="km" style="justify-content:center"><span class="km__dot"></span>KM 05 · Endstation: eure Bühne</span>
      <h2 class="cta__title">Holt euch Brass.313<br />auf eure Bühne</h2>
      <p class="lead mx-auto center">
        Konzert, Festzelt, Firmenfeier oder Event-Umrahmung — schreibt uns, und wir stimmen
        alles individuell auf euren Anlass ab.
      </p>
      <div class="hero__actions" style="justify-content:center;margin-top:2rem">
        <a class="btn btn-primary" href={`mailto:${SITE.email}`}>{SITE.email}</a>
        <a class="btn btn-ghost" href={url('kontakt')}>Zum Kontaktformular</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* HERO */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    padding-bottom: clamp(3rem, 8vh, 5.5rem);
    overflow: hidden;
  }
  .hero__media { position: absolute; inset: 0; z-index: -1; }
  .hero__media img { width: 100%; height: 100%; object-fit: cover; object-position: center 30%; }
  .hero__overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(22,19,15,0.5) 0%, rgba(22,19,15,0.15) 32%, rgba(22,19,15,0.86) 86%, var(--nacht) 100%),
      radial-gradient(120% 80% at 18% 92%, rgba(182,130,46,0.2), transparent 60%);
  }
  .hero__content { position: relative; }
  .hero__sign { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.4rem; }
  .hero__sign-cap {
    font-family: var(--font-sign);
    font-size: 0.72rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--muted);
    max-width: 14ch;
    line-height: 1.4;
  }
  .hero__title { margin: 0 0 0.3rem -0.04em; }
  .hero__title .dot { color: var(--signal); }
  .hero__claim {
    font-family: var(--font-body);
    font-style: italic;
    font-size: clamp(1.4rem, 4vw, 2.5rem);
    color: var(--messing-hell);
    margin-bottom: 1.3rem;
  }
  .hero__lead { margin-bottom: 2rem; }
  .hero__actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  /* INTRO */
  .intro { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: clamp(2rem, 6vw, 5rem); align-items: center; }
  .intro .btn { margin-top: 1.8rem; }
  .intro__images { position: relative; aspect-ratio: 4/5; }
  .intro__img {
    position: absolute;
    object-fit: cover;
    border-radius: 4px;
    box-shadow: 0 30px 60px -25px rgba(0,0,0,0.85);
    border: 1px solid var(--line);
  }
  .intro__img--a { width: 72%; height: 82%; top: 0; left: 0; z-index: 2; }
  .intro__img--b { width: 52%; height: 56%; bottom: 0; right: 0; z-index: 3; }
  .intro__formation {
    position: absolute;
    top: 6%;
    right: 2%;
    z-index: 4;
    font-family: var(--font-sign);
    font-weight: 700;
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    color: var(--nacht);
    background: var(--signal);
    padding: 0.3em 0.5em;
    border-radius: 4px;
    box-shadow: inset 0 0 0 3px var(--nacht), 0 10px 30px -10px rgba(255,210,30,0.5);
  }
  @media (max-width: 820px) { .intro { grid-template-columns: 1fr; } .intro__images { max-width: 440px; } }

  /* SECTION HEAD */
  .sec-head { margin-bottom: 3rem; }
  .sec-head .section-title { margin-top: 0.7rem; }
  .sec-head--row { display: flex; align-items: flex-end; justify-content: space-between; gap: 2rem; }

  /* SEGMENTS */
  .segments-sec { background: linear-gradient(180deg, transparent, rgba(237,230,216,0.02)); }
  .segments { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); border-radius: 4px; overflow: hidden; }
  .segment {
    background: var(--nacht);
    padding: 2rem 1.5rem;
    transition: background 0.4s var(--ease);
  }
  .segment:hover { background: var(--nacht-2); }
  .segment__tag {
    font-family: var(--font-sign);
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--messing-tief);
  }
  .segment__title { font-size: 1.35rem; margin: 0.7rem 0 0.6rem; color: var(--messing-hell); }
  .segment__text { font-size: 0.95rem; }
  @media (max-width: 900px) { .segments { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .segments { grid-template-columns: 1fr; } }

  /* STOPS (gigs as route stops) */
  .stops { list-style: none; position: relative; }
  .stops::before { content: ''; position: absolute; left: 5px; top: 12px; bottom: 12px; width: 2px; background: var(--line-strong); }
  .stop {
    position: relative;
    display: grid;
    grid-template-columns: 78px 1fr auto;
    gap: 1.8rem;
    align-items: center;
    padding: 1.5rem 0 1.5rem 2.4rem;
    border-bottom: 1px solid var(--line);
  }
  .stop:first-child { border-top: 1px solid var(--line); }
  .stop__node {
    position: absolute;
    left: 0;
    top: 50%;
    width: 12px;
    height: 12px;
    transform: translateY(-50%);
    border-radius: 50%;
    background: var(--nacht);
    border: 2px solid var(--messing);
    transition: background 0.35s var(--ease), border-color 0.35s var(--ease), box-shadow 0.35s var(--ease);
  }
  .stop:hover .stop__node { background: var(--signal); border-color: var(--signal); box-shadow: 0 0 14px 0 rgba(255,210,30,0.5); }
  .stop__date { display: flex; flex-direction: column; align-items: flex-start; }
  .stop__day { font-family: var(--font-sign); font-weight: 700; font-size: 2.3rem; line-height: 0.9; color: var(--messing-hell); }
  .stop__month { font-family: var(--font-sign); font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--dim); }
  .stop__title { font-size: 1.5rem; }
  .stop__meta { text-align: right; font-family: var(--font-sign); }
  .stop__time { display: block; font-weight: 600; letter-spacing: 0.04em; }
  .stop__note { font-size: 0.82rem; letter-spacing: 0.08em; text-transform: uppercase; }
  @media (max-width: 660px) {
    .stop { grid-template-columns: 64px 1fr; gap: 1.1rem; }
    .stop__meta { grid-column: 2; text-align: left; }
  }

  /* BAND STRIP */
  .band-strip { position: relative; padding-block: clamp(5.5rem, 13vw, 10rem); overflow: hidden; }
  .band-strip__media { position: absolute; inset: 0; z-index: -1; }
  .band-strip__media img { width: 100%; height: 100%; object-fit: cover; object-position: center 22%; }
  .band-strip__overlay { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(22,19,15,0.96) 0%, rgba(22,19,15,0.78) 48%, rgba(22,19,15,0.42) 100%); }
  .band-strip__content { max-width: 640px; }
  .band-strip__content .section-title { margin: 0.7rem 0 0; }
  .band-names { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem 1.3rem; margin: 1.6rem 0 2rem; }
  .band-names li {
    font-family: var(--font-body);
    font-size: clamp(1.1rem, 2.4vw, 1.55rem);
    position: relative;
    padding-right: 1.3rem;
  }
  .band-names li:not(:last-child)::after { content: '·'; position: absolute; right: 0; color: var(--messing); }

  /* CTA */
  .cta { text-align: center; max-width: 760px; }
  .cta .km { display: inline-flex; }
  .cta__title { font-size: clamp(2.4rem, 6.5vw, 4.6rem); margin: 0.7rem 0 1.4rem; }
</style>
