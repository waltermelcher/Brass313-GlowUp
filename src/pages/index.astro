---
import Layout from '../layouts/Layout.astro';
import { SITE, OFFERS, GIGS, MUSICIANS, asset } from '../consts';

const offerImgs = ['images/gig-01.jpg', 'images/band-03.jpg', 'images/gig-05.jpg', 'images/band-06.jpg'];
const groups = [
  { n: 3, label: 'Hohe Bläser', sub: 'Trompeten & Flügelhörner' },
  { n: 1, label: 'Schlagzeug', sub: 'Das treibende Rückgrat' },
  { n: 3, label: 'Tiefe Bläser', sub: 'Posaunen & Tuba' },
];
---

<Layout>
  <!-- ============ HERO ============ -->
  <section id="start" class="hero">
    <div class="hero__media">
      <img src={asset('images/gig-01.jpg')} alt="Brass.313 live" fetchpriority="high" />
      <div class="hero__overlay"></div>
    </div>
    <div class="container hero__content">
      <span class="km" data-reveal><span class="km__dot"></span>Blaskapelle aus Württemberg</span>
      <h1 class="display hero__title" data-reveal style="--reveal-delay:.08s">Brass<span class="dot">.</span>313</h1>
      <p class="hero__claim" data-reveal style="--reveal-delay:.16s">{SITE.claim}</p>
      <p class="lead hero__lead" data-reveal style="--reveal-delay:.24s">{SITE.description}</p>
      <div class="hero__actions" data-reveal style="--reveal-delay:.32s">
        <a class="btn btn-primary" href="#termine">Termine ansehen <span class="arr">→</span></a>
        <a class="btn btn-ghost" href="#kontakt">Buchungsanfrage</a>
      </div>
    </div>
  </section>

  <!-- ============ Wer wir sind ============ -->
  <section id="band" class="section-pad">
    <div class="container intro">
      <div class="intro__text">
        <span class="km" data-reveal><span class="km__dot"></span>Wer wir sind</span>
        <h2 class="section-title" data-reveal>Sieben Musiker,<br />eine Leidenschaft</h2>
        <div class="stack" data-reveal style="--reveal-delay:.1s">
          <p class="lead">
            Brass.313 verbindet traditionelle Blasmusik mit modernen Pop-Arrangements zu einem
            einzigartigen Klangerlebnis — handgemacht, druckvoll und mit Herz.
          </p>
          <p class="muted">
            Der Name verrät die Besetzung: <span class="brass-text">3 hohe Bläser</span>,
            <span class="brass-text">1 Schlagzeuger</span> und
            <span class="brass-text">3 tiefe Bläser</span> — die <span class="brass-text">313</span>
            steht für unsere Heimat im Ländle.
          </p>
        </div>
        <a class="btn btn-ghost" href="#musiker" data-reveal style="--reveal-delay:.18s">Die Besetzung <span class="arr">→</span></a>
      </div>
      <div class="intro__images" data-reveal style="--reveal-delay:.12s">
        <img class="intro__img intro__img--a" src={asset('images/band-01.jpg')} alt="Brass.313 Porträt" loading="lazy" />
        <img class="intro__img intro__img--b" src={asset('images/gig-02.jpg')} alt="Brass.313 beim Auftritt" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ============ Auftritte ============ -->
  <section id="auftritte" class="section-pad segments-sec">
    <div class="container">
      <div class="sec-head" data-reveal>
        <span class="km"><span class="km__dot"></span>Auftritte</span>
        <h2 class="section-title">Für jeden Anlass<br />der richtige Sound</h2>
      </div>
      <div class="segments">
        {OFFERS.map((o, i) => (
          <article class="segment" data-reveal style={`--reveal-delay:${i * 0.07}s`}>
            <span class="segment__tag">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="segment__title">{o.title}</h3>
            <p class="segment__text muted">{o.text}</p>
          </article>
        ))}
      </div>

      <div class="gallery" data-reveal style="margin-top:1.6rem">
        <img src={asset(offerImgs[0])} alt="Brass.313 live" loading="lazy" />
        <img src={asset('images/gig-02.jpg')} alt="Brass.313 Auftritt" loading="lazy" />
        <img src={asset('images/band-08.jpg')} alt="Brass.313 Ensemble" loading="lazy" />
        <img src={asset('images/band-03.jpg')} alt="Brass.313 Bühne" loading="lazy" />
        <img src={asset('images/gig-05.jpg')} alt="Brass.313 Konzert" loading="lazy" />
        <img src={asset('images/band-06.jpg')} alt="Brass.313 Porträt" loading="lazy" />
      </div>

      <figure class="video" data-reveal>
        <div class="video__frame">
          <iframe
            src="https://www.youtube-nocookie.com/embed/bLXX4lsloVU"
            title="Brass.313 — Video"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          ></iframe>
        </div>
        <figcaption class="video__cap muted">Brass.313 live — ein Einblick</figcaption>
      </figure>
    </div>
  </section>

  <!-- ============ Termine ============ -->
  <section id="termine" class="section-pad">
    <div class="container">
      <div class="sec-head" data-reveal>
        <span class="km"><span class="km__dot"></span>Termine 2026</span>
        <h2 class="section-title">Wo ihr uns hört</h2>
        <p class="lead" style="margin-top:0.8rem">Kommt vorbei und erlebt Brass.313 live.</p>
      </div>

      <ul class="gig-list">
        {GIGS.map((g, i) => (
          <li class="gig" data-reveal style={`--reveal-delay:${i * 0.06}s`}>
            <div class="gig__date">
              <span class="gig__day">{g.day}</span>
              <span class="gig__month">{g.month}</span>
              <span class="gig__year">2026</span>
            </div>
            <div class="gig__main">
              <h3 class="gig__title">{g.title}</h3>
              <p class="gig__loc muted">{g.location}</p>
            </div>
            <div class="gig__meta">
              {i === 0 && <span class="gig__next">Nächster Termin</span>}
              <span class="gig__time">{g.time}</span>
              <span class="gig__note">{g.note}</span>
            </div>
          </li>
        ))}
      </ul>
      <p class="gig-note muted" data-reveal>Alle Angaben ohne Gewähr — Änderungen vorbehalten.</p>
    </div>
  </section>

  <!-- ============ Musiker ============ -->
  <section id="musiker" class="section-pad musiker-sec">
    <div class="container">
      <div class="sec-head" data-reveal>
        <span class="km"><span class="km__dot"></span>Die Besetzung</span>
        <h2 class="section-title">Die Musiker von Brass.313</h2>
        <p class="lead" style="margin-top:0.8rem">Sieben Musiker, ein Sound.</p>
      </div>
      <ul class="members">
        {MUSICIANS.map((m, i) => (
          <li class="member" data-reveal style={`--reveal-delay:${(i % 4) * 0.06}s`}>
            <div class="member__photo">
              <img src={asset(m.image)} alt={m.name} loading="lazy" />
            </div>
            <h3 class="member__name">{m.name}</h3>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Formation 3·1·3 + Fotos -->
  <section class="section-pad">
    <div class="container">
      <div class="sec-head" data-reveal>
        <span class="km"><span class="km__dot"></span>Die Formation</span>
        <h2 class="section-title">Warum 313?</h2>
        <p class="lead" style="margin-top:1rem">
          Der Name verrät die Besetzung — und die Heimat: drei hohe Bläser, ein Schlagzeuger und
          drei tiefe Bläser. Die <span class="brass-text">313</span> steht für unser Ländle, aus dem
          die Band stammt.
        </p>
      </div>

      <div class="formation" data-reveal>
        <div class="formation__line"></div>
        {groups.map((g) => (
          <div class="fgroup">
            <span class="fgroup__num">{g.n}</span>
            <div class="fgroup__notes">
              {Array.from({ length: g.n }).map(() => <span class="note"></span>)}
            </div>
            <h3 class="fgroup__label">{g.label}</h3>
            <p class="fgroup__sub muted">{g.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ Kontakt ============ -->
  <section id="kontakt" class="section-pad kontakt-sec">
    <div class="container">
      <div class="sec-head center mx-auto" data-reveal>
        <span class="km" style="justify-content:center"><span class="km__dot"></span>Buchung &amp; Kontakt</span>
        <h2 class="section-title">Holt euch Brass.313 auf eure Bühne</h2>
      </div>

      <div class="contact">
        <aside class="contact__info" data-reveal>
          <ul class="contact__list">
            <li>
              <span class="contact__label">E-Mail</span>
              <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
            </li>
            <li>
              <span class="contact__label">Instagram</span>
              <a href={SITE.instagram} target="_blank" rel="noopener">@brass.313</a>
            </li>
            <li>
              <span class="contact__label">Region</span>
              <span class="contact__plain">Württemberg · im Ländle</span>
            </li>
          </ul>
          <p class="contact__note muted">
            Für Buchungsanfragen nennt uns gern Datum, Ort, Anlass und die gewünschte Auftrittsform —
            so können wir euch direkt ein passendes Angebot machen.
          </p>
        </aside>

        <form class="contact__form" id="contact-form" data-reveal style="--reveal-delay:.1s">
          <div class="field">
            <label for="name">Name</label>
            <input id="name" name="name" type="text" required placeholder="Euer Name" />
          </div>
          <div class="field">
            <label for="email">E-Mail</label>
            <input id="email" name="email" type="email" required placeholder="name@beispiel.de" />
          </div>
          <div class="field">
            <label for="anlass">Anlass / Datum</label>
            <input id="anlass" name="anlass" type="text" placeholder="z. B. Sommerfest, 12.07.2026" />
          </div>
          <div class="field">
            <label for="nachricht">Nachricht</label>
            <textarea id="nachricht" name="nachricht" rows="5" required placeholder="Erzählt uns von eurem Anlass …"></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Nachricht senden <span class="arr">→</span></button>
          <p class="contact__hint muted">Öffnet euer E-Mail-Programm mit vorausgefüllter Nachricht.</p>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* HERO */
  .hero { position: relative; min-height: 100svh; display: flex; align-items: flex-end; padding-bottom: clamp(3rem, 8vh, 5.5rem); overflow: hidden; }
  .hero__media { position: absolute; inset: 0; z-index: -1; }
  .hero__media img { width: 100%; height: 100%; object-fit: cover; object-position: center 30%; }
  .hero__overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(22,19,15,0.5) 0%, rgba(22,19,15,0.15) 32%, rgba(22,19,15,0.86) 86%, var(--nacht) 100%),
      radial-gradient(120% 80% at 18% 92%, rgba(182,130,46,0.2), transparent 60%);
  }
  .hero__content { position: relative; }
  .hero__title { margin: 0.6rem 0 0.3rem -0.04em; }
  .hero__title .dot { color: var(--signal); }
  .hero__claim { font-family: var(--font-body); font-style: italic; font-size: clamp(1.4rem, 4vw, 2.5rem); color: var(--messing-hell); margin-bottom: 1.3rem; }
  .hero__lead { margin-bottom: 2rem; }
  .hero__actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  /* INTRO */
  .intro { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: clamp(2rem, 6vw, 5rem); align-items: center; }
  .intro .btn { margin-top: 1.8rem; }
  .intro__images { position: relative; aspect-ratio: 4/5; }
  .intro__img { position: absolute; object-fit: cover; border-radius: 4px; box-shadow: 0 30px 60px -25px rgba(0,0,0,0.85); border: 1px solid var(--line); }
  .intro__img--a { width: 72%; height: 82%; top: 0; left: 0; z-index: 2; }
  .intro__img--b { width: 52%; height: 56%; bottom: 0; right: 0; z-index: 3; }
  @media (max-width: 820px) { .intro { grid-template-columns: 1fr; } .intro__images { max-width: 440px; } }

  /* SECTION HEAD */
  .sec-head { margin-bottom: 3rem; }
  .sec-head .section-title { margin-top: 0.7rem; }

  /* SEGMENTS */
  .segments-sec { background: linear-gradient(180deg, transparent, rgba(237,230,216,0.02)); }
  .segments { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); border-radius: 4px; overflow: hidden; }
  .segment { background: var(--nacht); padding: 2rem 1.5rem; transition: background 0.4s var(--ease); }
  .segment:hover { background: var(--nacht-2); }
  .segment__tag { font-family: var(--font-sign); font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--messing-tief); }
  .segment__title { font-size: 1.35rem; margin: 0.7rem 0 0.6rem; color: var(--messing-hell); }
  .segment__text { font-size: 0.95rem; }
  @media (max-width: 900px) { .segments { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .segments { grid-template-columns: 1fr; } }

  /* GALLERY */
  .gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.8rem; }
  .gallery img { width: 100%; aspect-ratio: 4/3; object-fit: cover; border-radius: 4px; border: 1px solid var(--line); filter: grayscale(0.2) brightness(0.95); transition: transform 0.5s var(--ease), filter 0.5s var(--ease); }
  .gallery img:hover { transform: scale(1.02); filter: none; }
  @media (max-width: 760px) { .gallery { grid-template-columns: repeat(2, 1fr); } }

  /* TERMINE (Event-Karten) */
  .gig-list { list-style: none; display: flex; flex-direction: column; gap: 0.9rem; }
  .gig { display: grid; grid-template-columns: 92px 1fr auto; gap: 1.8rem; align-items: center; padding: 1.5rem 1.6rem; background: var(--nacht-2); border: 1px solid var(--line); border-radius: 4px; transition: border-color 0.35s var(--ease), transform 0.35s var(--ease); }
  .gig:hover { border-color: var(--messing-tief); transform: translateX(4px); }
  .gig__date { display: flex; flex-direction: column; align-items: flex-start; border-right: 1px solid var(--line); padding-right: 1.2rem; }
  .gig__day { font-family: var(--font-sign); font-weight: 700; font-size: 2.6rem; line-height: 0.85; color: var(--messing-hell); }
  .gig__month { font-family: var(--font-sign); font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text); margin-top: 0.2rem; }
  .gig__year { font-family: var(--font-sign); font-size: 0.66rem; letter-spacing: 0.18em; color: var(--dim); }
  .gig__title { font-size: clamp(1.4rem, 3vw, 2rem); }
  .gig__meta { text-align: right; font-family: var(--font-sign); }
  .gig__next { display: block; font-size: 0.6rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--signal); margin-bottom: 0.3rem; }
  .gig__time { display: block; font-weight: 600; font-size: 1.05rem; letter-spacing: 0.04em; }
  .gig__note { font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
  .gig-note { margin-top: 1.2rem; font-size: 0.86rem; }
  /* VIDEO */
  .video { margin-top: clamp(2.5rem, 5vw, 4rem); }
  .video__frame {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: #000;
    box-shadow: 0 30px 60px -30px rgba(0,0,0,0.8);
  }
  .video__frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
  .video__cap { margin-top: 0.9rem; font-family: var(--font-sign); font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; }
  @media (max-width: 660px) {
    .gig { grid-template-columns: 74px 1fr; gap: 1rem; }
    .gig__meta { grid-column: 2; text-align: left; }
  }

  /* MUSIKER (Foto-Karten) */
  .musiker-sec { background: linear-gradient(180deg, transparent, rgba(237,230,216,0.02)); }
  .members { list-style: none; display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.2rem; }
  .member__photo {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    border-radius: 4px;
    border: 1px solid var(--line);
    background: var(--nacht-2);
  }
  .member__photo img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 25%;
    filter: grayscale(0.25) brightness(0.92);
    transition: transform 0.5s var(--ease), filter 0.5s var(--ease);
  }
  .member:hover .member__photo img { transform: scale(1.04); filter: none; }
  .member__name { font-family: var(--font-body); font-weight: 500; font-size: 1.25rem; text-transform: none; letter-spacing: 0; margin-top: 0.9rem; }
  @media (max-width: 900px) { .members { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 560px) { .members { grid-template-columns: repeat(2, 1fr); gap: 1rem; } }

  /* FORMATION */
  .formation { position: relative; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 3rem; padding: 2.5rem 0; }
  .formation__line { position: absolute; left: 0; right: 0; top: 50%; height: 1px; background: linear-gradient(90deg, transparent, var(--messing-tief) 12%, var(--messing-tief) 88%, transparent); }
  .fgroup { position: relative; text-align: center; background: var(--nacht); padding: 1.5rem 1rem; }
  .fgroup__num { font-family: var(--font-sign); font-weight: 700; font-size: clamp(3rem, 8vw, 5rem); color: var(--messing-hell); line-height: 1; text-shadow: 0 0 40px var(--messing-glow); }
  .fgroup__notes { display: flex; justify-content: center; gap: 0.5rem; margin: 1rem 0; }
  .note { width: 16px; height: 16px; border-radius: 50%; background: var(--messing); box-shadow: 0 0 0 4px rgba(182,130,46,0.16); }
  .fgroup:nth-child(4) .note { background: var(--signal); box-shadow: 0 0 0 4px rgba(255,210,30,0.18); }
  .fgroup__label { font-size: 1.3rem; margin-bottom: 0.3rem; }
  .fgroup__sub { font-size: 0.92rem; }
  @media (max-width: 720px) {
    .formation { grid-template-columns: 1fr; gap: 0; }
    .formation__line { left: 50%; right: auto; top: 0; bottom: 0; width: 1px; height: auto; background: linear-gradient(180deg, transparent, var(--messing-tief) 12%, var(--messing-tief) 88%, transparent); }
  }

  /* KONTAKT */
  .kontakt-sec { background: linear-gradient(180deg, transparent, rgba(237,230,216,0.02)); }
  .kontakt-sec .sec-head { max-width: 40ch; }
  .contact { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: clamp(2rem, 6vw, 5rem); align-items: start; }
  .contact__list { list-style: none; display: flex; flex-direction: column; gap: 1.3rem; margin-bottom: 2rem; }
  .contact__list li { display: flex; flex-direction: column; gap: 0.3rem; padding-bottom: 1.3rem; border-bottom: 1px solid var(--line); }
  .contact__label { font-family: var(--font-sign); font-size: 0.7rem; letter-spacing: 0.24em; text-transform: uppercase; color: var(--dim); }
  .contact__list a, .contact__plain { font-family: var(--font-body); font-size: 1.25rem; }
  .contact__list a { color: var(--messing-hell); transition: color 0.3s var(--ease); }
  .contact__list a:hover { color: var(--signal); }
  .contact__note { font-size: 0.96rem; }
  .contact__form { background: var(--nacht); border: 1px solid var(--line); border-radius: 4px; padding: clamp(1.6rem, 4vw, 2.6rem); }
  .field { margin-bottom: 1.3rem; }
  .field label { display: block; font-family: var(--font-sign); font-size: 0.74rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.5rem; }
  .field input, .field textarea { width: 100%; background: var(--nacht-2); border: 1px solid var(--line-strong); border-radius: 3px; padding: 0.85rem 1rem; color: var(--text); font-family: var(--font-body); font-size: 1rem; transition: border-color 0.3s var(--ease), box-shadow 0.3s var(--ease); }
  .field input::placeholder, .field textarea::placeholder { color: var(--dim); }
  .field input:focus, .field textarea:focus { outline: none; border-color: var(--messing-hell); box-shadow: 0 0 0 3px rgba(231,184,92,0.16); }
  .field textarea { resize: vertical; }
  .contact__hint { font-size: 0.82rem; margin-top: 1rem; }
  @media (max-width: 820px) { .contact { grid-template-columns: 1fr; } }
</style>

<script is:inline define:vars={{ email: SITE.email }}>
  const form = document.getElementById('contact-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const name = data.get('name') || '';
    const from = data.get('email') || '';
    const anlass = data.get('anlass') || '';
    const msg = data.get('nachricht') || '';
    const subject = `Anfrage Brass.313${anlass ? ' — ' + anlass : ''}`;
    const body = `Name: ${name}\nE-Mail: ${from}\nAnlass/Datum: ${anlass}\n\n${msg}`;
    window.location.href = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  });
</script>
