---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { SITE } from '../consts';
---

<Layout title="Kontakt" description="Kontaktiert Brass.313 für Anfragen, Abstimmungen und Buchungen.">
  <PageHero
    eyebrow="Kontakt"
    title="Schreibt uns"
    text="Kontaktiert uns für Anfragen, Abstimmungen und weitere Informationen — wir freuen uns auf eure Nachricht."
    image="images/band-06.jpg"
  />

  <section class="section-pad">
    <div class="container contact">
      <!-- Info -->
      <aside class="contact__info" data-reveal>
        <h2 class="contact__head">Direkt erreichen</h2>
        <ul class="contact__list">
          <li>
            <span class="contact__label">E-Mail</span>
            <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
          </li>
          <li>
            <span class="contact__label">Instagram</span>
            <a href={SITE.instagram} target="_blank" rel="noopener">@brass.313</a>
          </li>
          <li>
            <span class="contact__label">Region</span>
            <span>Württemberg · entlang der B313</span>
          </li>
        </ul>
        <p class="contact__note">
          Für Buchungsanfragen nennt uns gern Datum, Ort, Anlass und die gewünschte Auftrittsform —
          so können wir euch direkt ein passendes Angebot machen.
        </p>
      </aside>

      <!-- Form -->
      <form class="contact__form" id="contact-form" data-reveal style="--reveal-delay:.1s">
        <div class="field">
          <label for="name">Name</label>
          <input id="name" name="name" type="text" required placeholder="Euer Name" />
        </div>
        <div class="field">
          <label for="email">E-Mail</label>
          <input id="email" name="email" type="email" required placeholder="name@beispiel.de" />
        </div>
        <div class="field">
          <label for="anlass">Anlass / Datum</label>
          <input id="anlass" name="anlass" type="text" placeholder="z. B. Sommerfest, 12.07.2026" />
        </div>
        <div class="field">
          <label for="nachricht">Nachricht</label>
          <textarea id="nachricht" name="nachricht" rows="5" required placeholder="Erzählt uns von eurem Anlass …"></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Nachricht senden</button>
        <p class="contact__hint">Öffnet euer E-Mail-Programm mit vorausgefüllter Nachricht.</p>
      </form>
    </div>
  </section>
</Layout>

<style>
  .contact {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }
  .contact__head { font-size: 1.8rem; margin-bottom: 1.8rem; }
  .contact__list { list-style: none; display: flex; flex-direction: column; gap: 1.4rem; margin-bottom: 2rem; }
  .contact__list li { display: flex; flex-direction: column; gap: 0.25rem; padding-bottom: 1.4rem; border-bottom: 1px solid var(--line); }
  .contact__label { font-size: 0.74rem; letter-spacing: 0.24em; text-transform: uppercase; color: var(--text-dim); }
  .contact__list a, .contact__list span:not(.contact__label) { font-size: 1.2rem; font-family: var(--font-display); }
  .contact__list a { color: var(--gold); transition: color 0.3s var(--ease); }
  .contact__list a:hover { color: var(--gold-bright); }
  .contact__note { color: var(--text-muted); font-size: 0.96rem; }

  .contact__form {
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: clamp(1.6rem, 4vw, 2.6rem);
  }
  .field { margin-bottom: 1.3rem; }
  .field label {
    display: block;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }
  .field input, .field textarea {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--line-strong);
    border-radius: 10px;
    padding: 0.85rem 1rem;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 1rem;
    transition: border-color 0.3s var(--ease), box-shadow 0.3s var(--ease);
  }
  .field input::placeholder, .field textarea::placeholder { color: var(--text-dim); }
  .field input:focus, .field textarea:focus {
    outline: none;
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(201,162,75,0.18);
  }
  .field textarea { resize: vertical; }
  .contact__hint { font-size: 0.82rem; color: var(--text-dim); margin-top: 1rem; }

  @media (max-width: 820px) { .contact { grid-template-columns: 1fr; } }
</style>

<script is:inline define:vars={{ email: SITE.email }}>
  const form = document.getElementById('contact-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const name = data.get('name') || '';
    const from = data.get('email') || '';
    const anlass = data.get('anlass') || '';
    const msg = data.get('nachricht') || '';
    const subject = `Anfrage Brass.313${anlass ? ' — ' + anlass : ''}`;
    const body =
      `Name: ${name}\nE-Mail: ${from}\nAnlass/Datum: ${anlass}\n\n${msg}`;
    window.location.href =
      `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  });
</script>
