---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { MUSICIANS, url, asset } from '../consts';

const groups = [
  { n: 3, label: 'Hohe Bläser', sub: 'Trompeten & Flügelhörner' },
  { n: 1, label: 'Schlagzeug', sub: 'Das treibende Rückgrat' },
  { n: 3, label: 'Tiefe Bläser', sub: 'Posaunen & Tuba' },
];
---

<Layout title="Musiker" description="Sieben Musiker, eine Leidenschaft — das Ensemble hinter Brass.313 und die Formation 3·1·3.">
  <PageHero
    km="M"
    label="Die Besetzung"
    title="Sieben Musiker, ein Sound"
    text="Hinter Brass.313 stehen sieben Freunde, die ihre Leidenschaft für handgemachte Blasmusik auf jede Bühne bringen."
    image="images/band-03.jpg"
  />

  <!-- Formation 3·1·3 als Notenlinie / Strecke -->
  <section class="section-pad" data-km="M1" data-label="Die Formation">
    <div class="container lane">
      <div class="sec-head" data-reveal>
        <span class="km"><span class="km__dot"></span>Die Formation</span>
        <h2 class="section-title">Warum 313?</h2>
        <p class="lead" style="margin-top:1rem">
          Der Name verrät die Besetzung — und die Heimat: drei hohe Bläser, ein Schlagzeuger, drei
          tiefe Bläser. Die <span class="brass-text">313</span> steht zugleich für die Bundesstraße
          B313, die sich durch unser Ländle zieht.
        </p>
      </div>

      <div class="formation" data-reveal>
        <div class="formation__line"></div>
        {groups.map((g) => (
          <div class="fgroup">
            <span class="fgroup__num">{g.n}</span>
            <div class="fgroup__notes">
              {Array.from({ length: g.n }).map(() => <span class="note"></span>)}
            </div>
            <h3 class="fgroup__label">{g.label}</h3>
            <p class="fgroup__sub muted">{g.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Die sieben Namen -->
  <section class="section-pad" style="padding-top:0" data-km="M2" data-label="Die Band">
    <div class="container lane">
      <div class="sec-head" data-reveal>
        <span class="km"><span class="km__dot"></span>Die Band</span>
        <h2 class="section-title">Das sind wir</h2>
      </div>
      <ul class="members">
        {MUSICIANS.map((m, i) => (
          <li class="member" data-reveal style={`--reveal-delay:${(i % 4) * 0.06}s`}>
            <span class="member__idx">{String(i + 1).padStart(2, '0')}</span>
            <span class="member__name">{m.name}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="members-photos" data-km="M3" data-label="Auf der Bühne">
    <div class="container lane">
      <div class="members-grid">
        <img src={asset('images/band-01.jpg')} alt="Brass.313" loading="lazy" data-reveal />
        <img src={asset('images/band-06.jpg')} alt="Brass.313" loading="lazy" data-reveal style="--reveal-delay:.06s" />
        <img src={asset('images/gig-02.jpg')} alt="Brass.313" loading="lazy" data-reveal style="--reveal-delay:.12s" />
      </div>
    </div>
  </section>

  <section class="section-pad" data-km="M4" data-label="Live erleben">
    <div class="container lane cta center" data-reveal>
      <h2 class="cta__title">Lust, uns live zu erleben?</h2>
      <div class="actions" style="margin-top:1.5rem">
        <a class="btn btn-primary" href={url('termine')}>Zu den Terminen <span class="arr">→</span></a>
        <a class="btn btn-ghost" href={url('kontakt')}>Kontakt</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .formation {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 3.5rem;
    padding: 2.5rem 0;
  }
  /* the staff line / road running through the formation */
  .formation__line { position: absolute; left: 0; right: 0; top: 50%; height: 2px; background: repeating-linear-gradient(to right, var(--messing-tief) 0 14px, transparent 14px 28px); }
  .fgroup {
    position: relative;
    text-align: center;
    background: var(--nacht);
    padding: 1.5rem 1rem;
  }
  .fgroup__num {
    font-family: var(--font-sign);
    font-weight: 700;
    font-size: clamp(3rem, 8vw, 5rem);
    color: var(--messing-hell);
    line-height: 1;
    text-shadow: 0 0 40px var(--messing-glow);
  }
  .fgroup__notes { display: flex; justify-content: center; gap: 0.5rem; margin: 1rem 0; }
  .note {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--messing);
    box-shadow: 0 0 0 4px rgba(182,130,46,0.16);
  }
  .fgroup:nth-child(3) .note { background: var(--signal); box-shadow: 0 0 0 4px rgba(255,210,30,0.18); }
  .fgroup__label { font-size: 1.3rem; margin-bottom: 0.3rem; }
  .fgroup__sub { font-size: 0.92rem; }
  @media (max-width: 720px) {
    .formation { grid-template-columns: 1fr; gap: 0; }
    .formation__line { left: 50%; right: auto; top: 0; bottom: 0; width: 2px; height: auto; background: repeating-linear-gradient(to bottom, var(--messing-tief) 0 14px, transparent 14px 28px); }
  }

  .members { list-style: none; display: grid; grid-template-columns: repeat(2, 1fr); }
  .member {
    display: flex;
    align-items: baseline;
    gap: 1.1rem;
    padding: 1.3rem 0.4rem;
    border-bottom: 1px solid var(--line);
    transition: padding-left 0.35s var(--ease);
  }
  .member:hover { padding-left: 1.1rem; }
  .member:hover .member__name { color: var(--messing-hell); }
  .member__idx { font-family: var(--font-sign); font-weight: 600; color: var(--messing); font-size: 0.9rem; min-width: 2.4ch; }
  .member__name { font-family: var(--font-body); font-size: clamp(1.4rem, 3vw, 2rem); transition: color 0.35s var(--ease); }
  @media (max-width: 600px) { .members { grid-template-columns: 1fr; } }

  .members-photos { padding-bottom: clamp(3rem, 8vw, 6rem); }
  .members-grid { display: grid; grid-template-columns: 1.4fr 1fr 1fr; gap: 0.8rem; }
  .members-grid img { width: 100%; height: 100%; aspect-ratio: 3/4; object-fit: cover; border-radius: 4px; border: 1px solid var(--line); }
  .members-grid img:first-child { aspect-ratio: auto; }
  @media (max-width: 760px) {
    .members-grid { grid-template-columns: 1fr 1fr; }
    .members-grid img:first-child { grid-column: span 2; aspect-ratio: 16/10; }
  }

  .cta { max-width: 700px; }
  .cta__title { font-size: clamp(2.2rem, 5vw, 3.4rem); }
  .actions { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }
</style>
