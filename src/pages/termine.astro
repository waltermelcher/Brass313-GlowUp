---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { GIGS, url } from '../consts';
---

<Layout title="Termine" description="Alle Stationen der Brass.313-Route 2026 — anstehende Auftritte und Konzerte.">
  <PageHero
    km="T"
    label="Nächster Halt"
    title="Die Route 2026"
    text="Jeder Auftritt ist eine Station auf der Strecke. Kommt vorbei und erlebt Brass.313 live."
    image="images/gig-05.jpg"
  />

  <section class="section-pad" data-km="T1" data-label="Stationen">
    <div class="container lane">
      <ol class="route-stops">
        {GIGS.map((g, i) => (
          <li class="rstop" data-reveal style={`--reveal-delay:${i * 0.06}s`}>
            <div class="rstop__marker">
              <span class="rstop__node"></span>
              {i === 0 && <span class="rstop__badge">Nächster Halt</span>}
            </div>
            <div class="rstop__card">
              <div class="rstop__date">
                <span class="rstop__day">{g.day}</span>
                <span class="rstop__month">{g.month}</span>
                <span class="rstop__year">2026</span>
              </div>
              <div class="rstop__main">
                <h2 class="rstop__title">{g.title}</h2>
                <p class="rstop__loc muted">{g.location}</p>
              </div>
              <div class="rstop__meta">
                <span class="rstop__time">{g.time}</span>
                <span class="rstop__note">{g.note}</span>
              </div>
            </div>
          </li>
        ))}
      </ol>

      <div class="endcap" data-reveal>
        <p class="muted">Alle Angaben ohne Gewähr — Änderungen vorbehalten. Ihr wollt Brass.313 für euren eigenen Anlass auf die Route holen?</p>
        <a class="btn btn-primary" href={url('kontakt')}>Buchungsanfrage stellen <span class="arr">→</span></a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .route-stops { list-style: none; position: relative; }
  /* the road through the stops */
  .route-stops::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: repeating-linear-gradient(to bottom, var(--messing-tief) 0 12px, transparent 12px 26px);
  }
  .rstop { position: relative; padding-left: 2.8rem; padding-bottom: 1.2rem; }
  .rstop__marker { position: absolute; left: 0; top: 1.7rem; }
  .rstop__node {
    position: absolute;
    left: 0;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--nacht);
    border: 3px solid var(--messing);
    transition: background 0.35s var(--ease), border-color 0.35s var(--ease), box-shadow 0.35s var(--ease);
  }
  .rstop:first-child .rstop__node { background: var(--signal); border-color: var(--signal); box-shadow: 0 0 16px 0 rgba(255,210,30,0.55); }
  .rstop:hover .rstop__node { background: var(--messing-hell); border-color: var(--messing-hell); }
  .rstop__badge {
    position: absolute;
    left: 28px;
    top: -2px;
    font-family: var(--font-sign);
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--signal);
    white-space: nowrap;
  }

  .rstop__card {
    display: grid;
    grid-template-columns: 92px 1fr auto;
    gap: 1.8rem;
    align-items: center;
    padding: 1.5rem 1.6rem;
    background: var(--nacht-2);
    border: 1px solid var(--line);
    border-radius: 4px;
    transition: border-color 0.35s var(--ease), transform 0.35s var(--ease);
  }
  .rstop:hover .rstop__card { border-color: var(--messing-tief); transform: translateX(4px); }
  .rstop__date { display: flex; flex-direction: column; align-items: flex-start; border-right: 1px solid var(--line); padding-right: 1.2rem; }
  .rstop__day { font-family: var(--font-sign); font-weight: 700; font-size: 2.6rem; line-height: 0.85; color: var(--messing-hell); }
  .rstop__month { font-family: var(--font-sign); font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text); margin-top: 0.2rem; }
  .rstop__year { font-family: var(--font-sign); font-size: 0.66rem; letter-spacing: 0.18em; color: var(--dim); }
  .rstop__title { font-size: clamp(1.4rem, 3vw, 2rem); }
  .rstop__meta { text-align: right; font-family: var(--font-sign); }
  .rstop__time { display: block; font-weight: 600; font-size: 1.05rem; letter-spacing: 0.04em; }
  .rstop__note { font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }

  .endcap {
    margin-top: 1rem;
    margin-left: 2.8rem;
    padding: 2.4rem;
    text-align: center;
    background: var(--nacht-2);
    border: 1px solid var(--line);
    border-radius: 4px;
  }
  .endcap p { max-width: 52ch; margin: 0 auto 1.5rem; }

  @media (max-width: 660px) {
    .rstop__card { grid-template-columns: 74px 1fr; gap: 1rem; }
    .rstop__meta { grid-column: 2; text-align: left; }
    .endcap { margin-left: 0; }
  }
</style>
